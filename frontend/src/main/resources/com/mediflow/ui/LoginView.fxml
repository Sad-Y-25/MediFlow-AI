<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mediflow.ui.controller.LoginController">
    <padding>
        <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
    </padding>

    <!-- Titre de l'application -->
    <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="MediFlow AI" />
    <Label style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;" text="Veuillez vous connecter pour continuer" />

    <!-- Champs de saisie -->
    <TextField fx:id="emailField" maxWidth="300.0" promptText="Adresse Email" style="-fx-padding: 10px; -fx-background-radius: 5px; -fx-border-color: #bdc3c7; -fx-border-radius: 5px;" />
    
    <PasswordField fx:id="passwordField" maxWidth="300.0" promptText="Mot de passe" style="-fx-padding: 10px; -fx-background-radius: 5px; -fx-border-color: #bdc3c7; -fx-border-radius: 5px;" />

    <!-- Bouton de connexion -->
    <Button maxWidth="300.0" onAction="#handleLogin" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Se connecter" />

    <!-- Message d'erreur (invisible par défaut) -->
    <Label fx:id="errorLabel" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;" text="" />

</VBox>