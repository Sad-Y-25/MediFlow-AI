<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.*?>
<?import java.lang.*?>

<HBox spacing="20" style="-fx-padding: 20; -fx-background-color: #f8f9fa;"
      xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mediflow.ui.controller.DashboardController"
        stylesheets="@/style.css">

    <!-- Section Gauche : Formulaire de Saisie -->
    <VBox spacing="15" prefWidth="280" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #dee2e6; -fx-border-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
        <Label text="Nouveau Patient" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

        <VBox spacing="5">
            <Label text="Nom complet :"/>
            <TextField fx:id="nameInput" promptText="ex: Jean Dupont"/>
        </VBox>

        <VBox spacing="5">
            <Label text="Email du patient :"/>
            <TextField fx:id="emailInput" promptText="ex: patient@gmail.com"/>
        </VBox>

        <VBox spacing="5">
            <Label text="Motif :"/>
            <TextField fx:id="reasonInput" promptText="ex: Douleur abdominale"/>
        </VBox>

        <VBox spacing="5">
            <Label text="Âge du patient :" />
            <TextField fx:id="ageInput" promptText="ex: 65" />
        </VBox>

        <VBox spacing="5">
            <Label text="Niveau d'Urgence :" />
            <ComboBox fx:id="urgencyInput" prefWidth="240">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="LOW" />
                        <String fx:value="MEDIUM" />
                        <String fx:value="HIGH" />
                    </FXCollections>
                </items>
                <value><String fx:value="LOW" /></value>
            </ComboBox>
        </VBox>

        <CheckBox fx:id="appointmentInput" text="Patient avec Rendez-vous (+15 pts)" style="-fx-text-fill: #2980b9; -fx-font-weight: bold;"/>

        <Button text="Ajouter à la file" onAction="#handleAddPatient"
                maxWidth="Infinity" styleClass="button-add"/>

        <Separator style="-fx-padding: 10 0;"/>

        <Button text="Actualiser la liste" onAction="#loadDataFromServer"
                maxWidth="Infinity" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>

        <Region VBox.vgrow="ALWAYS" /> <Button text="Déconnexion" onAction="#handleLogout"
                                               maxWidth="Infinity"
                                               style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </VBox>

    <!-- Section Droite : La File d'Attente -->
    <VBox spacing="10" HBox.hgrow="ALWAYS">
        <Label text="File d'attente MediFlow AI" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #34495e;"/>
        <HBox spacing="20" style="-fx-padding: 10; -fx-background-color: white; -fx-border-color: #dee2e6; -fx-border-radius: 5;">
            <VBox alignment="CENTER">
                <Label text="Total Patients" style="-fx-font-size: 12; -fx-text-fill: #7f8c8d;"/>
                <Label fx:id="totalStats" text="0" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2980b9;"/>
            </VBox>
            <Separator orientation="VERTICAL"/>
            <VBox alignment="CENTER">
                <Label text="Urgences (Niv. 5)" style="-fx-font-size: 12; -fx-text-fill: #7f8c8d;"/>
                <Label fx:id="urgentStats" text="0" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #c0392b;"/>
            </VBox>
        </HBox>
        <TextField fx:id="searchField" promptText="Rechercher un patient ou un motif..."
                   style="-fx-background-radius: 15; -fx-padding: 8;"/>
        <TableView fx:id="ticketTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idCol" text="Ticket" prefWidth="90"/>
                <TableColumn fx:id="nameCol" text="Nom du Patient" prefWidth="180"/>
                <TableColumn fx:id="urgencyCol" text="Urgence" prefWidth="80"/>
                <TableColumn fx:id="scoreCol" text="Score IA" prefWidth="80"/>
                <TableColumn fx:id="waitCol" text="Attente (min)" prefWidth="100"/>
                <TableColumn fx:id="actionCol" text="Actions" prefWidth="100"/>
            </columns>


        </TableView>
        <HBox spacing="10">
            <Button text="Voir l'Historique" onAction="#showHistory"
                    style="-fx-background-color: #34495e; -fx-text-fill: white;"/>
            <Button text="Gérer les Médecins" onAction="#showDoctors"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
            <Button text="Écran Salle d'Attente" onAction="#openWaitingRoom" style="-fx-background-color: #1abc9c; -fx-text-fill: white;"/>
        </HBox>
    </VBox>

</HBox>