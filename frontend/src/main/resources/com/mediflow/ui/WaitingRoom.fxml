<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="25" style="-fx-padding: 30; -fx-background-color: #1a252f;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mediflow.ui.controller.WaitingRoomController"
      stylesheets="@/style.css">

    <HBox alignment="CENTER" style="-fx-background-color: #2c3e50; -fx-padding: 20; -fx-background-radius: 10;">
        <VBox alignment="CENTER" spacing="5">
            <Label text="Salles de Consultation - File d'Attente" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
            <Label text="Affichage en temps réel des priorités médicales" style="-fx-font-size: 16px; -fx-text-fill: #bdc3c7;"/>
        </VBox>
    </HBox>

    <VBox spacing="15" VBox.vgrow="ALWAYS" style="-fx-background-color: #ffffff; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);">
        <HBox alignment="CENTER_LEFT">
            <Label text="Prochains patients appelés" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
            <Region HBox.hgrow="ALWAYS" />
            <ProgressIndicator prefWidth="25" prefHeight="25" style="-fx-progress-color: #3498db;" />
        </HBox>

        <TableView fx:id="publicQueueTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 18px;">
            <columns>
                <TableColumn fx:id="positionCol" text="Position" prefWidth="90" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="ticketCol" text="Code Ticket" prefWidth="160" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="patientCol" text="Patient (Anonymisé)" prefWidth="220" style="-fx-alignment: CENTER_LEFT;" />
                <TableColumn fx:id="doctorCol" text="Médecin / Service Affecté" prefWidth="250" style="-fx-alignment: CENTER_LEFT;" />
                <TableColumn fx:id="waitCol" text="Attente Estimée" prefWidth="140" style="-fx-alignment: CENTER;" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>

    <HBox alignment="CENTER" style="-fx-padding: 10;">
        <Label text="⚠️ L'ordre de passage est calculé dynamiquement par notre IA selon l'urgence médicale, et non l'ordre d'arrivée."
               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
    </HBox>
</VBox>